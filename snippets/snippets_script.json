{
    "API function buildModel (full)": {
    "prefix": "buildModel",
    "body": [
      "buildModel($1,",
      "           startTime = \"<default>\",",
      "           stopTime = 1.0,",
      "           numberOfIntervals = 500,",
      "           tolerance = 1e-6,",
      "           method = \"dassl\",",
      "           fileNamePrefix = \"<default>\",",
      "           options = \"<default>\",",
      "           outputFormat = \"mat\",",
      "           variableFilter = \".*\",",
      "           cflags = \"<default>\",",
      "           simflags = \"<default>\");"
    ],
    "scope": "source.openmodelica-script"
  },

  "API function buildModel": {
    "prefix": "buildModel",
    "body": [
      "buildModel($1);"
    ],
    "scope": "source.openmodelica-script"
  },

  "API function buildModelFMU (full)": {
    "prefix": "buildModelFMU",
    "body": [
      "buildModelFMU($1",
      "              version = \"2.0\",",
      "              fmuType = \"me\"",
      "              fileNamePrefix = \"<default>\",",
      "              platforms = {\"static\"},",
      "              includeResources = false);"
    ],
    "scope": "source.openmodelica-script"
  },

  "API function buildModelFMU": {
    "prefix": "buildModelFMU",
    "body": [
      "buildModelFMU($1);"
    ],
    "scope": "source.openmodelica-script"
  },

  "API function cd": {
    "prefix": "cd",
    "body": [
      "cd(\"$1\");"
    ],
    "description": "Changes the current working directory to the given path.",
    "scope": "source.openmodelica-script"
  },

  "API function diffSimulationResults": {
    "prefix": "diffSimulationResults",
    "body": [
      "diffSimulationResults(actualFile = \"$1\",",
      "                      expectedFile = \"$2\",",
      "                      diffPrefix = \"$3\");"
    ],
    "description": "Compares simulation results.",
    "scope": "source.openmodelica-script"
  },

  "API function echo": {
    "prefix": "echo",
    "body": [
      "echo($1);"
    ],
    "description": "Turns interactive output on or off.",
    "scope": "source.openmodelica-script"
  },

  "API function getErrorString": {
    "prefix": "getErrorString",
    "body": [
      "getErrorString();"
    ],
    "description": "Returns current error messages.\nReturns a user-friendly string containing the errors stored in the buffer. With warningsAsErrors=true, it reports warnings as if they were errors.",
    "scope": "source.openmodelica-script"
  },

  "API function getModelicaPath": {
    "prefix": "getModelicaPath",
    "body": [
      "getModelicaPath();"
    ],
    "description": "Returns the Modelica library path.",
    "scope": "source.openmodelica-script"
  },

  "API function getSimulationOptions": {
    "prefix": "getSimulationOptions",
    "body": [
      "getSimulationOptions($1);"
    ],
    "description": "Returns the startTime, stopTime, tolerance, and interval based on the experiment annotation.",
    "scope": "source.openmodelica-script"
  },

  "API function installPackage (full)": {
    "prefix": "installPackage",
    "body": [
      "installPackage($1,",
      "               version = \"\",",
      "               exactMatch = false);"
    ],
    "description": "Installs a package.",
    "scope": "source.openmodelica-script"
  },

  "API function installPackage": {
    "prefix": "installPackage",
    "body": [
      "installPackage($1);"
    ],
    "description": "Installs a package.",
    "scope": "source.openmodelica-script"
  },

  "API function loadFile": {
    "prefix": "loadFile",
    "body": [
      "loadFile(\"$1\");"
    ],
    "description": "Loads a Modelica file (*.mo).",
    "scope": "source.openmodelica-script"
  },

  "API function loadFiles": {
    "prefix": "loadFiles",
    "body": [
      "loadFiles({\"$1\"});"
    ],
    "description": "Loads Modelica files (*.mo).",
    "scope": "source.openmodelica-script"
  },

  "API function loadModel (full)": {
    "prefix": "loadModel",
    "body": [
      "loadModel($1,",
      "          priorityVersion = {\"default\"});"
    ],
    "scope": "source.openmodelica-script"
  },

  "API function loadModel": {
    "prefix": "loadModel",
    "body": [
      "loadModel($1, {\"$2\"});"
    ],
    "scope": "source.openmodelica-script"
  },

  "API function readFile": {
    "prefix": "readFile",
    "body": [
      "readFile(\"$1\");"
    ],
    "description": "Returns the contents of a file.",
    "scope": "source.openmodelica-script"
  },

  "API function setCommandLineOptions": {
    "prefix": "setCommandLineOptions",
    "body": [
      "setCommandLineOptions(\"$1\");"
    ],
    "description": "Sets command line options for the compiler.",
    "scope": "source.openmodelica-script"
  },

  "API function simulate (full)": {
    "prefix": "simulate",
    "body": [
      "simulate($1,",
      "         startTime = 0.0,",
      "         stopTime = 1.0,",
      "         numberOfIntervals = 500,",
      "         tolerance = 1e-6,",
      "         method = \"dassl\",",
      "         fileNamePrefix = \"<default>\",",
      "         options = \"\",",
      "         outputFormat = \"mat\",",
      "         variableFilter = \".*\",",
      "         cflags = \"\",",
      "         simflags = \"<default>\");"
    ],
    "description": "Simulates a model.",
    "scope": "source.openmodelica-script"
  },

  "API function simulate": {
    "prefix": "simulate",
    "body": [
      "simulate($1);"
    ],
    "description": "Simulates a model.",
    "scope": "source.openmodelica-script"
  },

  "API function updatePackageIndex": {
    "prefix": "updatePackageIndex",
    "body": [
      "updatePackageIndex();"
    ],
    "description": "Updates the package index.",
    "scope": "source.openmodelica-script"
  },

  "API function writeFile": {
    "prefix": "writeFile",
    "body": [
      "writeFile(\"$1\",",
      "          data = \"$2\");"
    ],
    "description": "Writes data to a file.",
    "scope": "source.openmodelica-script"
  },

  "Minimal Working Example": {
    "prefix": "loadModel",
    "body": [
      "loadModel(Modelica, {\"4.0\"});",
      "getErrorString();",
      "loadString(\"",
      "  model M",
      "    $1",
      "  end M;",
      "\"); getErrorString();",
      "simulate(M); getErrorString();"
    ],
    "description": "Loads a Modelica library.",
    "scope": "source.openmodelica-script"
  }
}
